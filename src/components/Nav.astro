---
const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/services', label: 'Services' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-cream border-b border-muted/20">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="text-ink font-semibold text-lg tracking-wide hover:text-burgundy transition-colors">
      Fatima Saleh
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-ink/80 hover:text-burgundy text-sm font-medium tracking-wide transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Hamburger (mobile) -->
    <button
      id="nav-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      class="md:hidden flex flex-col gap-1.5 p-2 text-ink"
    >
      <span class="block w-6 h-0.5 bg-current transition-transform duration-200 nav-bar-1"></span>
      <span class="block w-6 h-0.5 bg-current transition-opacity duration-200 nav-bar-2"></span>
      <span class="block w-6 h-0.5 bg-current transition-transform duration-200 nav-bar-3"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-cream border-t border-muted/20">
    <ul class="max-w-6xl mx-auto px-4 py-4 flex flex-col gap-4">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="block text-ink/80 hover:text-burgundy text-sm font-medium tracking-wide transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = toggle?.querySelector('.nav-bar-1') as HTMLElement | null;
  const bar2 = toggle?.querySelector('.nav-bar-2') as HTMLElement | null;
  const bar3 = toggle?.querySelector('.nav-bar-3') as HTMLElement | null;

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    if (bar1 && bar2 && bar3) {
      bar1.style.transform = isOpen ? 'translateY(8px) rotate(45deg)' : '';
      bar2.style.opacity = isOpen ? '0' : '1';
      bar3.style.transform = isOpen ? 'translateY(-8px) rotate(-45deg)' : '';
    }
  });
</script>
