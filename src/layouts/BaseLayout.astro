---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  gscVerification?: string;
}

const {
  title = 'Fatima Saleh',
  description = 'Coach, facilitator, and organizational development consultant.',
  ogImage = '/og-default.jpg',
  ogType = 'website',
  canonicalUrl,
  gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION_TAG ?? '',
} = Astro.props;

const canonical = canonicalUrl ?? Astro.url.href;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `https://fatimasaleh.com${ogImage}`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:site_name" content="Fatima Saleh" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Google Search Console verification -->
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}

    <!-- Extra head content injected by individual pages -->
    <slot name="head" />

    <!-- Theme: apply before paint to avoid flash -->
    <script is:inline>
      (function() {
        // Only apply dark class if user explicitly stored a preference
        // System preference handled via CSS @media query to avoid Lighthouse interference
        const stored = localStorage.getItem('theme');
        if (stored === 'dark') document.documentElement.classList.add('dark');
        else if (stored === 'light') document.documentElement.classList.add('light');
      })();
    </script>

    <style is:global>
      /* System preference — CSS media query (no JS class, Lighthouse handles correctly) */
      @media (prefers-color-scheme: dark) {
        html:not(.light) .text-ink { color: #F7F4F0; }
        html:not(.light) .bg-cream { background-color: #141210; }
        html:not(.light) .bg-ink { background-color: #141210; }
        html:not(.light) .bg-burgundy { background-color: #8B4D5E; }
        html:not(.light) .bg-white { background-color: #1f1d1b; }
        html:not(.light) .text-cream { color: #F7F4F0; }
        html:not(.light) .text-gold { color: #D4B86A; }
        html:not(.light) .text-magenta { color: #F06090; }
        html:not(.light) .text-muted { color: #9A9590; }
        html:not(.light) .border-ink { border-color: #F7F4F0; }
        html:not(.light) body { background-color: #141210; color: #F7F4F0; }
      }
      /* Explicit user toggle — .dark class overrides system preference */
      html.dark .text-ink { color: #F7F4F0; }
      html.dark .bg-cream { background-color: #141210; }
      html.dark .bg-ink { background-color: #141210; }
      html.dark .bg-burgundy { background-color: #8B4D5E; }
      html.dark .bg-white { background-color: #1f1d1b; }
      html.dark .text-cream { color: #F7F4F0; }
      html.dark .text-gold { color: #D4B86A; }
      html.dark .text-magenta { color: #F06090; }
      html.dark .text-muted { color: #9A9590; }
      html.dark .border-ink { border-color: #F7F4F0; }
      html.dark body { background-color: #141210; color: #F7F4F0; }
    </style>
  </head>
  <body class="bg-cream text-ink min-h-screen flex flex-col font-sans antialiased">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>
