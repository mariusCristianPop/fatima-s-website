---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

import heroImg from '../assets/8cfb7fa568d489ac3ca8fe9c01e11ec4.jpg';
import educationImg from '../assets/6cf52d7466e485819da0962b42d85e76.jpg';
import personal1 from '../assets/4ca318170583751c3336a868f7b2d180.jpg';
import personal2 from '../assets/214e01bd9ec7715eb57732e9532ca0ab.jpg';

import logoAyaan from '../assets/d1b19127b171d019b375774ae86a8622.png';
import logoSJ from '../assets/06d27964c6411abf85527429b09e6b23.png';
import logoBotH from '../assets/65164f3f3d2a172439875e41d1dbf90b.png';
import logoPrestige from '../assets/7be2c09af17ee5461fbbe4e0bd260bca.png';
import logoKalon from '../assets/3d43b0d62af39df458a4bad4618fa859.png';
import logoTuFemeie from '../assets/918f9739357c73c8c675b1313ab6a6d9.png';
import logoAR from '../assets/e5585549dd4a0ec638c61c2e75e4dd05.png';
import logoWonders from '../assets/cdadc2834440deb7dcc528a9d8e57419.png';

const education = [
  {
    degree: 'Master of Science — Accounting and Finance',
    institution: 'Arden University',
    year: '2026',
  },
  {
    degree: 'Bachelor of Arts (Hons) — Business Management and Leadership',
    institution: 'Coventry University London',
    year: '2023',
  },
  {
    degree: 'Secondary Education (12 Classes)',
    institution: 'Liceul Teoretic Dante Alighieri, Bucharest, Romania',
    year: '',
  },
];

const ventures = [
  {
    logo: logoAyaan,
    name: 'Ayaan & Co Services',
    description: "Leading the company's overall financial strategy, business operations, and corporate growth — overseeing financial planning, investment decisions, risk management, and regulatory compliance.",
  },
  {
    logo: logoSJ,
    name: 'SJ Prestige Events',
    description: 'Overseeing the overall management and operations of the event hall, ensuring every event is executed professionally and seamlessly — coordinating event planning, staff, and client relationships.',
  },
  {
    logo: logoBotH,
    name: 'Business on the Heels',
    description: 'Founded to empower ambitious women to grow, lead, and succeed in business — focusing on leadership development, entrepreneurship, financial confidence, and strong professional networks.',
  },
  {
    logo: logoPrestige,
    name: 'The Prestige Centre CIC',
    description: 'Leading community-focused initiatives to bring people together, create opportunities, and support local growth — serving as a welcoming hub for connection, collaboration, and development.',
  },
  {
    logo: logoKalon,
    name: 'Kalon Financial',
    description: 'As Protection Advisor & Area Sales Manager, helping individuals, families, and businesses secure their financial future through tailored protection solutions.',
  },
  {
    logo: logoTuFemeie,
    name: 'Tu Femeie Poți',
    description: "Founded to support and inspire women within the Romanian community — focusing on personal development, financial education, confidence-building, and creating a strong women's support network.",
  },
  {
    logo: logoAR,
    name: 'A&R Consultancy',
    description: "Supporting the daily operations of this family-owned accountancy firm — assisting with accounting and client management while maintaining high standards of accuracy and confidentiality.",
  },
  {
    logo: logoWonders,
    name: 'Wonders of Pakistan',
    description: "Working alongside my husband to import high-quality bedsheets and home textiles from Pakistan — managing supplier relationships, product selection, import logistics, and customer service.",
  },
];
---

<BaseLayout title="About — Fatima Saleh" description="Fatima Saleh is a finance professional, entrepreneur, and community leader dedicated to building businesses with purpose, structure, and long-term success.">

  <!-- Hero -->
  <section class="relative h-[90vh] min-h-[560px] flex items-end overflow-hidden">
    <Image
      src={heroImg}
      alt="Fatima Saleh"
      class="absolute inset-0 w-full h-full object-cover object-top"
      widths={[640, 1024, 1600]}
      sizes="100vw"
      fetchpriority="high"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/30 to-transparent"></div>
    <div class="relative z-10 max-w-6xl mx-auto w-full px-4 sm:px-6 pb-16 sm:pb-24 flex justify-end">
      <div class="max-w-xl text-right">
        <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-3">Founder · Coach · Community Leader</p>
        <h1 class="text-5xl sm:text-7xl font-bold text-cream leading-tight mb-4">
          Fatima Saleh
        </h1>
        <p class="text-lg sm:text-xl text-cream/85 leading-relaxed mb-2">
          MSc Accounting and Finance · BA Business Management and Leadership
        </p>
        <p class="text-cream/70 text-base leading-relaxed mb-8">
          Finance professional, entrepreneur, and community leader dedicated to building businesses with purpose, structure, and long-term success.
        </p>
        <div class="flex flex-wrap gap-4 justify-end">
          <a href="/coaching" class="inline-block bg-magenta text-cream px-7 py-3 text-sm font-semibold tracking-wide hover:bg-magenta/90 transition-colors">
            Work With Me
          </a>
          <a href="/contact" class="inline-block border border-cream text-cream px-7 py-3 text-sm font-semibold tracking-wide hover:bg-cream hover:text-ink transition-colors">
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="py-20 px-4 sm:px-6 bg-cream">
    <div class="max-w-6xl mx-auto">
      <p class="text-magenta text-xs font-semibold tracking-widest uppercase mb-4">Qualifications</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-ink mb-12">Education</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="space-y-6">
          {education.map((e) => (
            <div class="border-l-4 border-magenta pl-6 py-2">
              <p class="text-ink font-semibold text-lg leading-snug mb-1">{e.degree}</p>
              <p class="text-muted text-sm font-medium">{e.institution}{e.year ? ` · ${e.year}` : ''}</p>
            </div>
          ))}
        </div>
        <div class="overflow-hidden">
          <Image
            src={educationImg}
            alt="Fatima Saleh — Education"
            class="w-full h-full object-cover"
            widths={[480, 800]}
            sizes="(max-width: 1024px) 100vw, 50vw"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Personal -->
  <section class="py-20 px-4 sm:px-6 bg-ink">
    <div class="max-w-6xl mx-auto">
      <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-4">Beyond Business</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-cream mb-12">Personal</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6 text-cream/80 text-lg leading-relaxed">
          <p>
            Beyond my professional journey, I am a proud and happy mother of three beautiful children — two boys and one girl — who are my greatest inspiration and motivation. I have been happily married for over 10 years, and family remains at the heart of everything I do.
          </p>
          <p>
            I strongly believe in family values, integrity, respect, and leading by example. Balancing entrepreneurship, leadership, and motherhood has shaped my resilience, compassion, and determination.
          </p>
          <p>
            My family is my foundation, and they continuously inspire me to grow, achieve, and empower others to do the same.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="overflow-hidden aspect-[3/4]">
            <Image
              src={personal1}
              alt="Fatima Saleh — personal"
              class="w-full h-full object-cover"
              widths={[360, 600]}
              sizes="(max-width: 640px) 50vw, 25vw"
            />
          </div>
          <div class="overflow-hidden aspect-[3/4]">
            <Image
              src={personal2}
              alt="Fatima Saleh — personal"
              class="w-full h-full object-cover"
              widths={[360, 600]}
              sizes="(max-width: 640px) 50vw, 25vw"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ventures Overview -->
  <section class="py-20 px-4 sm:px-6 bg-cream">
    <div class="max-w-6xl mx-auto">
      <p class="text-magenta text-xs font-semibold tracking-widest uppercase mb-4">Portfolio</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-ink mb-12">What I Am Doing</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {ventures.map((v) => (
          <div class="flex flex-col items-center text-center border border-muted/20 p-8 bg-white hover:shadow-md transition-shadow">
            <div class="h-28 flex items-center justify-center mb-5">
              <Image src={v.logo} alt={v.name} class="max-h-28 w-auto object-contain" style="max-width: 220px;" />
            </div>
            <h3 class="text-ink font-semibold text-lg mb-3">{v.name}</h3>
            <p class="text-ink text-sm leading-relaxed">{v.description}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href="/ventures" class="inline-block border border-ink text-ink px-7 py-3 text-sm font-semibold tracking-wide hover:bg-ink hover:text-cream transition-colors">
          View All Ventures
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 sm:px-6 bg-burgundy">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-cream mb-4">Ready to Grow?</h2>
      <p class="text-cream/80 text-lg leading-relaxed mb-10">
        Whether you are starting out or scaling up, I am here to help you build with clarity and confidence.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/coaching" class="inline-block bg-cream text-burgundy px-8 py-3 text-sm font-semibold tracking-wide hover:bg-cream/90 transition-colors">
          Explore Coaching
        </a>
        <a href="/contact" class="inline-block border border-cream text-cream px-8 py-3 text-sm font-semibold tracking-wide hover:bg-cream/10 transition-colors">
          Get in Touch
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
