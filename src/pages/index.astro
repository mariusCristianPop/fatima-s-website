---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

import heroImg from '../assets/8cfb7fa568d489ac3ca8fe9c01e11ec4.jpg';
import logoAyaan from '../assets/d1b19127b171d019b375774ae86a8622.png';
import logoSJ from '../assets/06d27964c6411abf85527429b09e6b23.png';
import logoBotH from '../assets/65164f3f3d2a172439875e41d1dbf90b.png';
import logoPrestige from '../assets/7be2c09af17ee5461fbbe4e0bd260bca.png';
import testimonial1 from '../assets/61ad87ae69cce49d9cb69f48d38da03f.jpg';
import testimonial2 from '../assets/2c30fe92b039b70ad1ffd3f57ef7805b.jpg';
import testimonial3 from '../assets/da3605b83cd5dbb9bd443ac1f63efea5.jpg';
import testimonial4 from '../assets/d7316b07ecdf166f1bf371c9da325644.jpg';
import testimonial5 from '../assets/1475ce223090ca3cb726dd0bdcbd262c.jpg';
import testimonial6 from '../assets/545594ea5aab9a876c88e8ffcc171135.jpg';

const ventures = [
  {
    logo: logoAyaan,
    name: 'Ayaan & Co Services',
    description: 'A consultancy company supporting businesses with clarity, financial strategy, and direction.',
    href: '/ventures',
  },
  {
    logo: logoSJ,
    name: 'SJ Prestige Events',
    description: 'An exclusive event venue designed to host impactful and elegant experiences.',
    href: '/ventures',
  },
  {
    logo: logoBotH,
    name: 'Business on the Heels',
    description: 'A business network created to elevate Romanian women in entrepreneurship.',
    href: '/business-on-the-heels',
  },
  {
    logo: logoPrestige,
    name: 'The Prestige Centre CIC',
    description: 'Supporting and empowering the Romanian community through connection and development.',
    href: '/ventures',
  },
];

const testimonials = [
  { img: testimonial1, name: 'Sarah M.', quote: 'Fatima helped me transform my business vision into a clear, actionable plan. Her guidance was invaluable.' },
  { img: testimonial2, name: 'Ana P.', quote: 'Working with Fatima gave me the confidence and structure I needed to take my business to the next level.' },
  { img: testimonial3, name: 'Maria C.', quote: 'The community Fatima has built through Business on the Heels is genuinely life-changing.' },
  { img: testimonial4, name: 'Elena D.', quote: "Fatima's coaching approach is strategic, personal, and truly empowering. Highly recommend." },
  { img: testimonial5, name: 'Ioana R.', quote: 'She has a rare ability to see both the big picture and the fine details that make a business succeed.' },
  { img: testimonial6, name: 'Cristina B.', quote: 'My revenue grew by over 40% within six months of working with Fatima. The results speak for themselves.' },
];
---

<BaseLayout title="Fatima Saleh — Home" description="Founder, business coach, and community leader dedicated to building businesses with purpose, structure, and long-term success.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "name": "Fatima Saleh",
          "url": "https://fatimasaleh.com",
          "jobTitle": "Business Coach & Entrepreneur",
          "description": "Founder, business coach, and community leader dedicated to building businesses with purpose, structure, and long-term success.",
          "sameAs": []
        },
        {
          "@type": "WebSite",
          "name": "Fatima Saleh",
          "url": "https://fatimasaleh.com",
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": "https://fatimasaleh.com/?s={search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        }
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="relative h-[90vh] min-h-[560px] flex items-end overflow-hidden">
    <Image
      src={heroImg}
      alt="Fatima Saleh"
      class="absolute inset-0 w-full h-full object-cover object-top"
      widths={[640, 1024, 1600]}
      sizes="100vw"
      fetchpriority="high"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/30 to-transparent"></div>
    <div class="relative z-10 max-w-6xl mx-auto w-full px-4 sm:px-6 pb-16 sm:pb-24 flex justify-end">
      <div class="max-w-xl text-right">
        <p class="text-magenta text-xs font-semibold tracking-widest uppercase mb-3">Founder · Coach · Community Leader</p>
        <h1 class="text-5xl sm:text-7xl font-bold text-cream leading-tight mb-4">
          Fatima Saleh
        </h1>
        <p class="text-lg sm:text-xl text-cream/85 leading-relaxed mb-8">
          Building businesses with purpose, structure, and long-term success.
        </p>
        <div class="flex flex-wrap gap-4 justify-end">
          <a href="/coaching" class="inline-block bg-magenta text-cream px-7 py-3 text-sm font-semibold tracking-wide hover:bg-magenta/90 transition-colors">
            Work With Me
          </a>
          <a href="/contact" class="inline-block border border-cream text-cream px-7 py-3 text-sm font-semibold tracking-wide hover:bg-cream hover:text-ink transition-colors">
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Bio -->
  <section class="py-20 px-4 sm:px-6 bg-cream">
    <div class="max-w-3xl mx-auto">
      <p class="text-magenta text-xs font-semibold tracking-widest uppercase mb-4">About</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-ink mb-8">Fatima Saleh, MSc</h2>
      <p class="text-muted text-sm font-semibold tracking-widest uppercase mb-6">Founder | Business Coach</p>
      <div class="space-y-6 text-ink/80 text-lg leading-relaxed">
        <p>
          I'm Fatima — a finance professional, entrepreneur, and community leader dedicated to building businesses with purpose, structure, and long-term success.
        </p>
        <p>
          I am the founder of Ayaan & Co Services, a consultancy company supporting businesses with clarity and direction. I also own SJ Prestige Events Ltd, an exclusive event venue designed to host impactful and elegant experiences.
        </p>
        <p>
          Beyond business ownership, I serve as Director of The Prestige Centre CIC, supporting and empowering the Romanian community, and I am the Founder & CEO of Business on the Heels Club — a business network created to elevate Romanian women in entrepreneurship.
        </p>
      </div>
      <a href="/about" class="inline-block mt-10 border border-ink text-ink px-6 py-3 text-sm font-semibold tracking-wide hover:bg-ink hover:text-cream transition-colors">
        Read My Story
      </a>
    </div>
  </section>

  <!-- Ventures Preview -->
  <section id="portfolio" class="py-20 px-4 sm:px-6 bg-ink">
    <div class="max-w-6xl mx-auto">
      <p class="text-magenta text-xs font-semibold tracking-widest uppercase mb-4">Ventures</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-cream mb-12">What I'm Building</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {ventures.map((v) => (
          <a href={v.href} class="group flex flex-col items-center text-center bg-cream/5 border border-cream/10 p-8 hover:bg-cream/10 transition-colors">
            <div class="h-28 flex items-center justify-center mb-5">
              <Image src={v.logo} alt={v.name} class="max-h-28 w-auto object-contain" style="max-width: 220px;" />
            </div>
            <h3 class="text-cream font-semibold text-lg mb-2 group-hover:text-gold transition-colors">{v.name}</h3>
            <p class="text-cream/60 text-sm leading-relaxed flex-1">{v.description}</p>
            <span class="mt-6 text-magenta text-sm font-semibold tracking-wide">Learn more →</span>
          </a>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href="/ventures" class="inline-block border border-cream/30 text-cream px-7 py-3 text-sm font-semibold tracking-wide hover:border-cream hover:bg-cream/5 transition-colors">
          View All Ventures
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 px-4 sm:px-6 bg-cream">
    <div class="max-w-6xl mx-auto">
      <p class="text-magenta text-xs font-semibold tracking-widest uppercase mb-4">Testimonials</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-ink mb-12">What They Say</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div class="flex flex-col bg-white border border-muted/20 overflow-hidden">
            <button
              class="block w-full aspect-square overflow-hidden cursor-zoom-in testimonial-btn"
              data-index={i}
              aria-label={`View full image of ${t.name}`}
            >
              <Image src={t.img} alt={t.name} class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-300" widths={[400, 600]} sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw" />
            </button>
            <div class="p-6 flex flex-col flex-1">
              <p class="text-ink/75 text-sm leading-relaxed flex-1 italic mb-4">"{t.quote}"</p>
              <p class="text-ink font-semibold text-sm">{t.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.92);align-items:center;justify-content:center;">
    <button id="lightbox-close" style="position:absolute;top:1.25rem;right:1.5rem;color:#fff;font-size:2.5rem;line-height:1;background:none;border:none;cursor:pointer;" aria-label="Close">&times;</button>
    <button id="lightbox-prev" style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:#fff;font-size:2.5rem;line-height:1;background:none;border:none;cursor:pointer;padding:0.5rem;" aria-label="Previous">&#8249;</button>
    <img id="lightbox-img" src="" alt="" style="max-width:80vw;max-height:90vh;object-fit:contain;" />
    <button id="lightbox-next" style="position:absolute;right:1rem;top:50%;transform:translateY(-50%);color:#fff;font-size:2.5rem;line-height:1;background:none;border:none;cursor:pointer;padding:0.5rem;" aria-label="Next">&#8250;</button>
  </div>

  <script define:vars={{ srcs: testimonials.map(t => t.img.src) }}>
    const lb = document.getElementById('lightbox');
    const lbImg = document.getElementById('lightbox-img');
    let current = 0;

    function showImage(i) {
      current = (i + srcs.length) % srcs.length;
      lbImg.src = srcs[current];
    }

    document.querySelectorAll('.testimonial-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        showImage(parseInt(btn.dataset.index));
        lb.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      });
    });

    function closeLightbox() {
      lb.style.display = 'none';
      document.body.style.overflow = '';
    }

    document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
    document.getElementById('lightbox-prev').addEventListener('click', (e) => { e.stopPropagation(); showImage(current - 1); });
    document.getElementById('lightbox-next').addEventListener('click', (e) => { e.stopPropagation(); showImage(current + 1); });
    lb.addEventListener('click', (e) => { if (e.target === lb) closeLightbox(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') showImage(current - 1);
      if (e.key === 'ArrowRight') showImage(current + 1);
    });
  </script>

  <!-- CTA Strip -->
  <section class="py-20 px-4 sm:px-6 bg-burgundy">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-cream mb-4">Ready to Grow?</h2>
      <p class="text-cream/80 text-lg leading-relaxed mb-10">
        Whether you're starting out or scaling up, I'm here to help you build with clarity and confidence.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/coaching" class="inline-block bg-cream text-burgundy px-8 py-3 text-sm font-semibold tracking-wide hover:bg-cream/90 transition-colors">
          Explore Coaching
        </a>
        <a href="/business-on-the-heels" class="inline-block border border-cream text-cream px-8 py-3 text-sm font-semibold tracking-wide hover:bg-cream/10 transition-colors">
          Business on the Heels
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
