---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Fatima Saleh" description="The page you're looking for doesn't exist.">
  <section class="flex flex-col items-center justify-center min-h-[60vh] px-6 text-center">
    <p class="text-8xl font-serif font-bold text-burgundy mb-4">404</p>
    <h1 class="text-3xl font-serif font-bold text-ink mb-4">Page Not Found</h1>
    <p class="text-ink mb-10 max-w-md">The page you're looking for doesn't exist or may have moved.</p>
    <a
      href="/"
      class="inline-block bg-magenta text-white font-semibold py-3 px-8 rounded-lg hover:bg-magenta/90 transition focus:outline-none focus:ring-2 focus:ring-magenta/40"
    >
      Back to Home
    </a>
  </section>
</BaseLayout>
