---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

import heroImg from '../assets/b8a2dcef80aa4636803e6feb58d3547c.jpg';
import gallery1 from '../assets/483bb5deebbdb6fbbda1c06a8dcd6e9f.jpg';
import gallery2 from '../assets/5339ec34655a1f761c08f5437973f374.jpg';
import gallery3 from '../assets/57049b03848e31b26790cc00c54f4a11.jpg';
import gallery4 from '../assets/328aa93836d250a3e538d2c10240677b.jpg';
import gallery5 from '../assets/af733941fc9e0b94f99bcf33ad4d612b.jpg';

const services = [
  {
    title: 'Business Strategy & Planning',
    description: "We map out where you are, where you want to go, and exactly how to get there — with a clear, actionable roadmap built around your specific business, not a generic template.",
  },
  {
    title: 'Financial Clarity & Confidence',
    description: "Understand your numbers, identify profit leaks, set pricing that works, and build a financial foundation that supports sustainable growth.",
  },
  {
    title: 'Leadership & Mindset Coaching',
    description: "Step into your role as a business owner with confidence. We work on the mindset, decision-making, and leadership skills that separate businesses that survive from those that thrive.",
  },
  {
    title: 'Entrepreneurship Launch',
    description: "Taking your first steps into business? We help you structure, validate, and launch your idea the right way — reducing risk and accelerating your path to revenue.",
  },
  {
    title: 'Accountability & Growth Support',
    description: "Ongoing support that keeps you focused and moving. Regular check-ins, honest feedback, and the structure you need to stay consistent and achieve real results.",
  },
  {
    title: 'Community & Network Access',
    description: "Join a curated network of entrepreneurs and business leaders. The right connections can open doors, provide referrals, and offer perspectives that change how you think about your business.",
  },
];
---

<BaseLayout title="Coaching — Fatima Saleh" description="Work with Fatima Saleh for one-to-one business coaching and strategic guidance. Build clarity, confidence, and momentum in your business.">

  <!-- Hero -->
  <section class="relative h-[85vh] min-h-[520px] flex items-end overflow-hidden">
    <Image
      src={heroImg}
      alt="Fatima Saleh — Business Coaching"
      class="absolute inset-0 w-full h-full object-cover object-top"
      widths={[640, 1024, 1600]}
      sizes="100vw"
      fetchpriority="high"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/40 to-transparent"></div>
    <div class="relative z-10 max-w-6xl mx-auto w-full px-4 sm:px-6 pb-16 sm:pb-24">
      <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-3">1:1 Coaching</p>
      <h1 class="text-5xl sm:text-7xl font-bold text-cream leading-tight mb-6">
        Build With Clarity.<br />Lead With Confidence.
      </h1>
      <p class="text-lg sm:text-xl text-cream/85 max-w-2xl leading-relaxed mb-8">
        Strategic business coaching that helps ambitious entrepreneurs and professionals turn their vision into a structured, thriving reality.
      </p>
      <a href="/contact" class="inline-block bg-magenta text-cream px-8 py-3 text-sm font-semibold tracking-wide hover:bg-magenta/90 transition-colors">
        Work With Me
      </a>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="py-20 px-4 sm:px-6 bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6 text-ink text-lg leading-relaxed">
          <p class="text-magenta text-xs font-semibold tracking-widest uppercase">Why Coaching</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-ink">The Difference Between Working Hard and Working Smart</h2>
          <p class="text-ink">
            Most business owners are working hard. The problem is not effort — it is direction. Without a clear strategy, the right support, and genuine accountability, even the most motivated entrepreneurs find themselves busy but not growing.
          </p>
          <p class="text-ink">
            Coaching with Fatima is different. It is not generic advice or surface-level motivation. It is a deep, structured engagement with your specific business — your numbers, your challenges, your goals — and a commitment to helping you build something that lasts.
          </p>
          <p class="text-ink">
            Fatima brings over a decade of experience across finance, entrepreneurship, and community leadership. She has built and grown multiple businesses from the ground up. She knows what works — and what looks good on paper but falls apart in practice.
          </p>
        </div>
        <div class="overflow-hidden aspect-[3/4]">
          <Image
            src={gallery1}
            alt="Fatima Saleh coaching"
            class="w-full h-full object-cover object-top"
            widths={[480, 800]}
            sizes="(max-width: 1024px) 100vw, 50vw"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 px-4 sm:px-6 bg-ink">
    <div class="max-w-6xl mx-auto">
      <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-4">What We Cover</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-cream mb-12">Coaching Offers</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <div class="bg-cream/5 border border-cream/10 p-8">
            <h3 class="text-magenta font-semibold text-base mb-4">{s.title}</h3>
            <p class="text-cream/70 text-sm leading-relaxed">{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-20 px-4 sm:px-6 bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="overflow-hidden aspect-[3/4]">
          <Image
            src={gallery2}
            alt="Coaching session"
            class="w-full h-full object-cover"
            widths={[400, 700]}
            sizes="(max-width: 640px) 100vw, 33vw"
          />
        </div>
        <div class="overflow-hidden aspect-[3/4]">
          <Image
            src={gallery3}
            alt="Business workshop"
            class="w-full h-full object-cover"
            widths={[400, 700]}
            sizes="(max-width: 640px) 100vw, 33vw"
          />
        </div>
        <div class="overflow-hidden aspect-[3/4]">
          <Image
            src={gallery4}
            alt="Entrepreneur event"
            class="w-full h-full object-cover"
            widths={[400, 700]}
            sizes="(max-width: 640px) 100vw, 33vw"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-20 px-4 sm:px-6 bg-burgundy">
    <div class="max-w-6xl mx-auto">
      <p class="text-cream text-xs font-semibold tracking-widest uppercase mb-4">How It Works</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-cream mb-12">The Process</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { step: '01', title: 'Discovery Call', text: 'We start with a conversation. Understanding where you are and what you truly want to achieve.' },
          { step: '02', title: 'Strategy Session', text: 'A deep dive into your business — identifying gaps, strengths, and a clear path forward.' },
          { step: '03', title: 'Structured Coaching', text: 'Regular sessions with defined actions, accountability, and measurable progress milestones.' },
          { step: '04', title: 'Results & Growth', text: 'Tangible progress: stronger financials, clearer direction, and a business you are proud of.' },
        ].map((p) => (
          <div class="border-t-2 border-cream/30 pt-6">
            <p class="text-cream/70 text-sm font-bold mb-4">{p.step}</p>
            <h3 class="text-cream font-semibold text-base mb-3">{p.title}</h3>
            <p class="text-cream/70 text-sm leading-relaxed">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final image + CTA -->
  <section class="relative py-32 flex items-center overflow-hidden">
    <Image
      src={gallery5}
      alt="Fatima Saleh — coaching"
      class="absolute inset-0 w-full h-full object-cover object-top"
      widths={[640, 1024, 1600]}
      sizes="100vw"
      fetchpriority="high"
      loading="eager"
    />
    <div class="absolute inset-0 bg-ink/70"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-cream mb-6">Start Your Journey Today</h2>
      <p class="text-cream/80 text-lg leading-relaxed mb-10">
        A single conversation can change the trajectory of your business. Let us find out how we can work together.
      </p>
      <a href="/contact" class="inline-block bg-magenta text-cream px-8 py-3 text-sm font-semibold tracking-wide hover:bg-magenta/90 transition-colors">
        Book a Discovery Call
      </a>
    </div>
  </section>

</BaseLayout>
