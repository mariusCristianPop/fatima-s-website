---
import BaseLayout from '../layouts/BaseLayout.astro';

const submitted = Astro.url.searchParams.get('success') === 'true';
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? 'PLACEHOLDER_KEY';
---

<BaseLayout title="Contact | Fatima Saleh" description="Get in touch with Fatima Saleh.">
  <section class="max-w-2xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-serif font-bold text-ink mb-4">Get in Touch</h1>
    <p class="text-ink mb-10">Have a question or want to work together? Send a message and I'll get back to you shortly.</p>

    {submitted ? (
      <div class="bg-gold/10 border border-gold rounded-lg p-8 text-center">
        <svg class="w-12 h-12 text-gold mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h2 class="text-2xl font-serif font-bold text-ink mb-2">Message sent!</h2>
        <p class="text-ink">Thank you for reaching out. I'll be in touch soon.</p>
        <a href="/contact" class="inline-block mt-6 text-magenta hover:underline font-medium">Send another message</a>
      </div>
    ) : (
      <form method="POST" action="https://api.web3forms.com/submit" class="space-y-6">
        <input type="hidden" name="access_key" value={accessKey} />
        <input type="hidden" name="redirect" value="https://fatimasaleh.com/contact?success=true" />
        <input type="hidden" name="subject" value="New enquiry from fatimasaleh.com" />

        <div>
          <label for="name" class="block text-sm font-medium text-ink mb-1">Name <span class="text-magenta">*</span></label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 border border-ink/20 rounded-lg bg-white focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition placeholder-muted/70 text-ink"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-ink mb-1">Email <span class="text-magenta">*</span></label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 border border-ink/20 rounded-lg bg-white focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition placeholder-muted/70 text-ink"
            placeholder="your@email.com"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-ink mb-1">Message <span class="text-magenta">*</span></label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full px-4 py-3 border border-ink/20 rounded-lg bg-white focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition resize-none placeholder-muted/70 text-ink"
            placeholder="What's on your mind?"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-magenta text-white font-semibold py-3 px-8 rounded-lg hover:bg-magenta/90 transition focus:outline-none focus:ring-2 focus:ring-magenta/40"
        >
          Send Message
        </button>
      </form>
    )}
  </section>
</BaseLayout>
